@page
@model GestionUsuarios.WCF.Pages.UsuarioModel
@{
    ViewData["Title"] = Model.ModoEdicion ? "Editar Usuario" : "Nuevo Usuario";
}

<div class="max-w-md">

    <!-- Card Collapsed (Initial State) -->
    <div id="cardCollapsed" class="rounded-xl p-6 cursor-pointer bg-transparent hover:bg-magnetic-card/50 transition-colors @(Model.ModoEdicion || !string.IsNullOrEmpty(Model.Mensaje) ? "hidden" : "")" onclick="expandCard()">
        <div class="flex flex-col items-center justify-center py-8">
            <div class="w-16 h-16 rounded-2xl border border-magnetic-border flex items-center justify-center mb-4 hover:bg-magnetic-hover hover:border-magnetic-border-light transition-colors">
                <svg class="w-8 h-8 text-magnetic-text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
            </div>
            <h2 class="text-base font-semibold text-magnetic-text mb-1">Crear Nuevo Usuario</h2>
            <p class="text-xs text-magnetic-text-secondary">Haz clic para agregar un usuario</p>
        </div>
    </div>

    <!-- Card Expanded (Form State) -->
    <div id="cardExpanded" class="rounded-xl overflow-hidden relative @(Model.ModoEdicion || !string.IsNullOrEmpty(Model.Mensaje) ? "" : "hidden")">
        <!-- Header -->
        <div class="px-6 py-4 border-b border-magnetic-border-subtle flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-magnetic-border-subtle flex items-center justify-center">
                @if (Model.ModoEdicion)
                {
                    <svg class="w-4 h-4 text-magnetic-text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                }
                else
                {
                    <svg class="w-4 h-4 text-magnetic-text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                    </svg>
                }
            </div>
            <div>
                <h2 class="text-sm font-semibold text-magnetic-text">
                    @(Model.ModoEdicion ? "Editar Usuario" : "Nuevo Usuario")
                </h2>
            </div>
        </div>

        <!-- Form -->
        <div class="p-6">
            <form method="post" id="userForm">
                <input type="hidden" name="IdUsuario" value="@Model.IdUsuario" />

                <div class="space-y-4">
                    <!-- Nombre -->
                    <div>
                        <label for="Nombre" class="block text-[10px] font-medium text-magnetic-text-secondary mb-1.5 uppercase tracking-wider">
                            Nombre completo
                        </label>
                        <input type="text" id="Nombre" name="Nombre" value="@Model.Nombre"
                               required maxlength="100"
                               placeholder="Ej. Juan Pérez García"
                               class="w-full input-magnetic rounded-lg px-3.5 py-2.5 text-sm placeholder:text-magnetic-text-muted" />
                    </div>

                    <!-- Fecha y Sexo -->
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label for="FechaNacimiento" class="block text-[10px] font-medium text-magnetic-text-secondary mb-1.5 uppercase tracking-wider">
                                Fecha Nac.
                            </label>
                            <input type="date" id="FechaNacimiento" name="FechaNacimiento" value="@Model.FechaNacimiento"
                                   required
                                   class="w-full input-magnetic rounded-lg px-3 py-2.5 text-sm [color-scheme:dark]" />
                        </div>

                        <div>
                            <label for="Sexo" class="block text-[10px] font-medium text-magnetic-text-secondary mb-1.5 uppercase tracking-wider">
                                Sexo
                            </label>
                            <select id="Sexo" name="Sexo" required
                                    class="w-full input-magnetic rounded-lg px-3 py-2.5 text-sm appearance-none cursor-pointer">
                                <option value="" class="bg-magnetic-card">Seleccione</option>
                                <option value="Masculino" selected="@(Model.Sexo == "Masculino")" class="bg-magnetic-card">Masculino</option>
                                <option value="Femenino" selected="@(Model.Sexo == "Femenino")" class="bg-magnetic-card">Femenino</option>
                                <option value="Otro" selected="@(Model.Sexo == "Otro")" class="bg-magnetic-card">Otro</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="mt-6 flex items-center gap-3 pt-4 border-t border-magnetic-border-subtle">
                    <button type="submit"
                            class="flex items-center gap-2 px-4 py-2 btn-magnetic text-xs font-medium rounded-lg">
                        @if (Model.ModoEdicion)
                        {
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                            </svg>
                            <span>Actualizar</span>
                        }
                        else
                        {
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                            </svg>
                            <span>Guardar</span>
                        }
                    </button>

                    @if (Model.ModoEdicion)
                    {
                        <a href="/UsuarioConsulta"
                           class="flex items-center gap-2 px-4 py-2 bg-magnetic-border-subtle hover:bg-magnetic-hover text-magnetic-text-secondary hover:text-magnetic-text text-xs font-medium rounded-lg transition-all border border-transparent hover:border-magnetic-border">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
                            </svg>
                            Volver
                        </a>
                    }
                    else
                    {
                        <button type="button" onclick="collapseCard()"
                                class="flex items-center gap-2 px-4 py-2 bg-magnetic-border-subtle hover:bg-magnetic-hover text-magnetic-text-secondary hover:text-magnetic-text text-xs font-medium rounded-lg transition-all border border-transparent hover:border-magnetic-border">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                            Cancelar
                        </button>
                    }
                </div>
            </form>
        </div>
    </div>

    <!-- Back to Dashboard Link (only when collapsed) -->
    <div id="backLink" class="mt-4 text-center @(Model.ModoEdicion || !string.IsNullOrEmpty(Model.Mensaje) ? "hidden" : "")">
        <a href="/UsuarioConsulta" class="inline-flex items-center gap-1.5 text-xs text-magnetic-text-secondary hover:text-magnetic-text transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Volver al Dashboard
        </a>
    </div>
</div>

<script>
    function expandCard() {
        document.getElementById('cardCollapsed').classList.add('hidden');
        document.getElementById('cardExpanded').classList.remove('hidden');
        document.getElementById('backLink').classList.add('hidden');
        
        // Focus on first input after animation
        setTimeout(() => {
            document.getElementById('Nombre').focus();
        }, 100);
    }

    function collapseCard() {
        // Clear form
        document.getElementById('userForm').reset();
        
        // Hide expanded, show collapsed
        document.getElementById('cardExpanded').classList.add('hidden');
        document.getElementById('cardCollapsed').classList.remove('hidden');
        document.getElementById('backLink').classList.remove('hidden');
        
        // Hide alert if exists
        const alert = document.getElementById('alertMessage');
        if (alert) {
            alert.style.opacity = '0';
            alert.style.transform = 'translateY(20px)';
            setTimeout(function() {
                alert.style.display = 'none';
            }, 300);
        }
    }

    // Auto-expand if there's an error or we're in edit mode
    // Auto-collapse if success on creation (ModoEdicion = false, Exito = true)
    document.addEventListener('DOMContentLoaded', function() {
        const alert = document.getElementById('alertMessage');
        const hasMessage = alert !== null;
        const isEditMode = @Json.Serialize(Model.ModoEdicion);
        const isSuccess = @Json.Serialize(Model.Exito);
        
        if (isEditMode) {
            // Edit mode: always expand
            document.getElementById('cardCollapsed').classList.add('hidden');
            document.getElementById('cardExpanded').classList.remove('hidden');
            document.getElementById('backLink').classList.add('hidden');
        } else if (hasMessage && isSuccess) {
            // Creation success: stay collapsed (form already cleared by server)
            // Show the success message and collapsed view
            document.getElementById('cardCollapsed').classList.remove('hidden');
            document.getElementById('cardExpanded').classList.add('hidden');
            document.getElementById('backLink').classList.remove('hidden');
        } else if (hasMessage && !isSuccess) {
            // Creation error: expand to fix
            document.getElementById('cardCollapsed').classList.add('hidden');
            document.getElementById('cardExpanded').classList.remove('hidden');
            document.getElementById('backLink').classList.add('hidden');
        }
        // Initial load (no message, no edit): stay collapsed

        // Auto-hide alert messages after 4 seconds (except errors which stay until fixed)
        if (alert && isSuccess) {
            setTimeout(function() {
                alert.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
                alert.style.opacity = '0';
                alert.style.transform = 'translateY(20px)';
                setTimeout(function() {
                    alert.style.display = 'none';
                }, 500);
            }, 4000);
        }
    });
</script>

<!-- Alert Messages - Bottom Fixed -->
@if (!string.IsNullOrEmpty(Model.Mensaje))
{
    <div id="alertMessage" class="fixed bottom-5 right-5 px-4 py-3 rounded-lg border text-sm font-medium flex items-center gap-3 shadow-lg z-50
                @(Model.Exito ? "bg-magnetic-card border-magnetic-border text-magnetic-text" : "bg-red-500/10 border-red-500/30 text-red-400")">
        @if (Model.Exito)
        {
            <div class="w-6 h-6 rounded-full bg-magnetic-border flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-magnetic-text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
            </div>
        }
        else
        {
            <div class="w-6 h-6 rounded-full bg-red-500/20 flex items-center justify-center">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </div>
        }
        @Model.Mensaje
    </div>
}
