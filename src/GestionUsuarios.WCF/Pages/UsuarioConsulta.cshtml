@page
@model GestionUsuarios.WCF.Pages.UsuarioConsultaModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Stats Grid - Magnetic Style -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
    <!-- Stat Card 1 -->
    <div class="rounded-xl p-4">
        <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-lg bg-magnetic-border-subtle border border-magnetic-border flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-magnetic-text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
            </div>
            <div>
                <p class="text-2xl font-bold text-magnetic-text tabular-nums">@Model.Usuarios.Count</p>
                <p class="text-xs text-magnetic-text-secondary mt-0.5">Total usuarios</p>
            </div>
        </div>
    </div>

    <!-- Stat Card 2 -->
    <div class="rounded-xl p-4">
        <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-lg bg-magnetic-border-subtle border border-magnetic-border flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-magnetic-text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
            </div>
            <div>
                <p class="text-2xl font-bold text-magnetic-text tabular-nums">@Model.Usuarios.Count(u => u.Sexo == "Masculino")</p>
                <p class="text-xs text-magnetic-text-secondary mt-0.5">Masculino</p>
            </div>
        </div>
    </div>

    <!-- Stat Card 3 -->
    <div class="rounded-xl p-4">
        <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-lg bg-magnetic-border-subtle border border-magnetic-border flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-magnetic-text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
            </div>
            <div>
                <p class="text-2xl font-bold text-magnetic-text tabular-nums">@Model.Usuarios.Count(u => u.Sexo == "Femenino")</p>
                <p class="text-xs text-magnetic-text-secondary mt-0.5">Femenino</p>
            </div>
        </div>
    </div>
</div>

<!-- Two Column Layout -->
<div class="grid grid-cols-1 lg:grid-cols-12 gap-5">
    
    <!-- Left Column: Overview -->
    <div class="lg:col-span-4 space-y-4">
        
        <!-- Overview Card -->
        <div class="rounded-xl p-5">
            <h3 class="text-xs font-semibold text-magnetic-text uppercase tracking-wider mb-4">Resumen</h3>
            
            <div class="space-y-3">
                <div class="flex items-center justify-between py-2 border-b border-magnetic-border-subtle">
                    <span class="text-xs text-magnetic-text-secondary">Usuarios registrados</span>
                    <span class="text-sm font-medium text-magnetic-text">@Model.Usuarios.Count</span>
                </div>
                <div class="flex items-center justify-between py-2 border-b border-magnetic-border-subtle">
                    <span class="text-xs text-magnetic-text-secondary">Edad promedio</span>
                    <span class="text-sm font-medium text-magnetic-text">
                        @{
                            var edadPromedio = Model.Usuarios.Any() 
                                ? (int)Model.Usuarios.Average(u => DateTime.Now.Year - u.FechaNacimiento.Year) 
                                : 0;
                        }
                        @edadPromedio años
                    </span>
                </div>
                <div class="flex items-center justify-between py-2">
                    <span class="text-xs text-magnetic-text-secondary">Último registro</span>
                    <span class="text-sm font-medium text-magnetic-text">
                        @(Model.Usuarios.OrderByDescending(u => u.IdUsuario).FirstOrDefault()?.Nombre ?? "N/A")
                    </span>
                </div>
            </div>
        </div>

    </div>

    <!-- Right Column: Data Table -->
    <div class="lg:col-span-8">
        <div class="rounded-xl overflow-hidden">
            <div class="px-5 py-4 border-b border-magnetic-border-subtle flex items-center justify-between">
                <div>
                    <h3 class="text-xs font-semibold text-magnetic-text uppercase tracking-wider">Listado de Usuarios</h3>
                    <p class="text-xs text-magnetic-text-secondary mt-0.5">@Model.Usuarios.Count registros</p>
                </div>
                <a href="/Usuario"
                   class="flex items-center gap-1.5 px-3 py-1.5 btn-magnetic text-xs font-medium rounded-lg">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                    Nuevo
                </a>
            </div>

            @if (!Model.Usuarios.Any())
            {
                <div class="px-6 py-16 text-center">
                    <div class="w-14 h-14 rounded-xl bg-magnetic-border-subtle flex items-center justify-center mx-auto mb-4">
                        <svg class="w-7 h-7 text-magnetic-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                  d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </div>
                    <p class="text-sm text-magnetic-text-secondary">No hay usuarios registrados</p>
                    <a href="/Usuario" class="inline-flex items-center gap-1.5 mt-3 text-xs text-magnetic-text-secondary hover:text-magnetic-text">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                        </svg>
                        Crear el primero
                    </a>
                </div>
            }
            else
            {
                <div class="overflow-x-auto" id="usersTable">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-magnetic-border-subtle bg-magnetic-sidebar/50">
                                <th class="px-4 py-3 text-left text-[10px] font-medium text-magnetic-text-muted uppercase tracking-wider">ID</th>
                                <th class="px-4 py-3 text-left text-[10px] font-medium text-magnetic-text-muted uppercase tracking-wider">Nombre</th>
                                <th class="px-4 py-3 text-left text-[10px] font-medium text-magnetic-text-muted uppercase tracking-wider">Nacimiento</th>
                                <th class="px-4 py-3 text-left text-[10px] font-medium text-magnetic-text-muted uppercase tracking-wider">Sexo</th>
                                <th class="px-4 py-3 text-right text-[10px] font-medium text-magnetic-text-muted uppercase tracking-wider">Acciones</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-magnetic-border-subtle/50">
                            @foreach (var usuario in Model.Usuarios)
                            {
                                <tr class="hover:bg-magnetic-hover/50 transition-colors user-row group">
                                    <td class="px-4 py-3 text-magnetic-text-muted font-mono text-xs">#@usuario.IdUsuario</td>
                                    <td class="px-4 py-3 font-medium text-magnetic-text user-name">@usuario.Nombre</td>
                                    <td class="px-4 py-3 text-magnetic-text-secondary text-xs">@usuario.FechaNacimiento.ToString("dd/MM/yyyy")</td>
                                    <td class="px-4 py-3">
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-medium border bg-magnetic-border-subtle text-magnetic-text-secondary border-magnetic-border">
                                            @usuario.Sexo
                                        </span>
                                    </td>
                                    <td class="px-4 py-3 text-right">
                                        <div class="inline-flex items-center gap-2 opacity-80 group-hover:opacity-100 transition-opacity">
                                            <a href="/Usuario?id=@usuario.IdUsuario"
                                               class="inline-flex items-center gap-1 px-2.5 py-1.5 bg-magnetic-border-subtle hover:bg-magnetic-border text-magnetic-text-secondary hover:text-magnetic-text text-[10px] rounded transition-all border border-transparent hover:border-magnetic-border-light">
                                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                          d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                                </svg>
                                                Editar
                                            </a>
                                            <form method="post" asp-page-handler="Eliminar" class="inline"
                                                  onsubmit="return confirm('¿Eliminar a @usuario.Nombre?')">
                                                <input type="hidden" name="idUsuario" value="@usuario.IdUsuario" />
                                                <button type="submit"
                                                        class="inline-flex items-center gap-1 px-2.5 py-1.5 bg-red-500/5 hover:bg-red-500/15 text-red-400 text-[10px] rounded transition-all border border-red-500/20 hover:border-red-500/40">
                                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                              d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                                    </svg>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Alert Messages - Bottom Fixed -->
@if (!string.IsNullOrEmpty(Model.Mensaje))
{
    <div id="alertMessage" class="fixed bottom-5 right-5 px-4 py-3 rounded-lg border text-sm font-medium flex items-center gap-3 shadow-lg z-50
                @(Model.Exito ? "bg-magnetic-card border-magnetic-border text-magnetic-text" : "bg-red-500/10 border-red-500/30 text-red-400")">
        @if (Model.Exito)
        {
            <div class="w-6 h-6 rounded-full bg-magnetic-border flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-magnetic-text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
            </div>
        }
        else
        {
            <div class="w-6 h-6 rounded-full bg-red-500/20 flex items-center justify-center">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </div>
        }
        @Model.Mensaje
    </div>
}

<script>
    function filterTable() {
        const input = document.getElementById('searchInput');
        if (!input) return;
        const filter = input.value.toLowerCase();
        const rows = document.querySelectorAll('.user-row');
        
        rows.forEach(row => {
            const name = row.querySelector('.user-name').textContent.toLowerCase();
            row.style.display = name.includes(filter) ? '' : 'none';
        });
    }

    // Auto-hide alert messages after 4 seconds
    document.addEventListener('DOMContentLoaded', function() {
        const alert = document.getElementById('alertMessage');
        if (alert) {
            setTimeout(function() {
                alert.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
                alert.style.opacity = '0';
                alert.style.transform = 'translateY(20px)';
                setTimeout(function() {
                    alert.style.display = 'none';
                }, 500);
            }, 4000);
        }
    });
</script>
